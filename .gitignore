# Environments
# python/ <- We now track the base python runtime, but ignore heavy site-packages
python/Lib/site-packages/*
python/Scripts/*
python/share/*
python/etc/*
!python/Lib/site-packages/pip/
!python/Lib/site-packages/pip-*/
!python/Lib/site-packages/setuptools/
!python/Lib/site-packages/setuptools-*/
!python/Lib/site-packages/pkg_resources/
!python/Scripts/pip*.exe

.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[co]
*$py.class

# PyInstaller
*.manifest
*.spec

# Distribution / packaging
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg

# Testing files
*.exr
*.nk
*.autosave

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# AI Models & Weights
models/
weights/
checkpoints/

# Temporary run artifacts & downloaded repos
temp_masks/
temp_vggsfm_repo/
*.db
0/
1/
CHECK.txt
pairs.txt

# Test scripts
test_*.py
